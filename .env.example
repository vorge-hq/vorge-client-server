# App
NODE_ENV=development

# Client
CLIENT_PORT=5173
VITE_API_BASE_URL=http://localhost:4000

# Server
SERVER_PORT=4000
JWT_SECRET=replace_me_with_a_strong_secret
JWT_EXPIRES_IN=1h

# Database
POSTGRES_DB=vantage
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@db:5432/vantage

# Security
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:5173

 # Database (production/staging extras)
  # Direct (non-pooled) connection for migrations
  only; app uses DATABASE_URL
  MIGRATE_DATABASE_URL=
  # TLS to the database; defaults to true when
  NODE_ENV=production
  DATABASE_SSL=false

  # Cookies
  # strict (default) | lax | none — cross-site
  deploys (Vercel client ↔ Render API)
  # need "none", which requires Secure cookies
  COOKIE_SAME_SITE=strict

# AI service module (P4) — single egress via the Vercel AI Gateway
# Master switch; features 404 cleanly when off. Required with a key in production.
AI_ENABLED=false
AI_GATEWAY_API_KEY=
# Per-feature model override (gateway "provider/model" ids). Leave unset to use
# the defaults in server/src/ai/config.js — no code change needed to switch.
AI_MODEL_DRAFTED_SUMMARY=
AI_MODEL_ANOMALY=
AI_MODEL_TAGGING=
AI_MODEL_CONSISTENCY=
AI_MODEL_EMBEDDINGS=


