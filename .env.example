# App
# Local Docker / laptop. Staging URLs belong in `.env.staging` (gitignored),
# not here — a second DATABASE_URL in `.env` overrides the local one and
# empties the assessments list. Use: make migrate-staging / make seed-staging.
NODE_ENV=development

# Client
CLIENT_PORT=5173
VITE_API_BASE_URL=http://localhost:4000
# false = real API (needed for live AI smoke). true = fixture demo personas.
VITE_ENABLE_DEMO=false

# Server
SERVER_PORT=4000
JWT_SECRET=replace_me_with_a_strong_secret
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=30d
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict
CORS_ORIGIN=http://localhost:5173
BCRYPT_ROUNDS=12
MFA_ENCRYPTION_KEY=replace_me_with_openssl_rand_base64_32

# Database — LOCAL Docker Compose only (`db` hostname inside containers;
# make migrate/seed rewrite `@db` → `@localhost` on the host).
POSTGRES_DB=vantage
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@db:5432/vantage

# AI service module (P4) — single egress via the Vercel AI Gateway
AI_ENABLED=false
AI_GATEWAY_API_KEY=
# Per-feature model override (gateway "provider/model" ids). Leave unset for defaults.
AI_MODEL_DRAFTED_SUMMARY=
AI_MODEL_ANOMALY=
AI_MODEL_TAGGING=
AI_MODEL_CONSISTENCY=
AI_MODEL_EMBEDDINGS=

# Nightly consistency job (P4 O7) — `npm --prefix server run job:consistency`.
# Runs outside any request, so it sets no facility RLS context: it needs an
# owner/BYPASSRLS connection or RLS hides every entitled facility and the job
# silently flags nothing. Leave UNSET locally (Docker's DATABASE_URL is already
# the owner). On staging/prod it MUST be set — DATABASE_URL there is the
# non-owner `vorge_app` role. The job refuses to run if the role isn't exempt.
CONSISTENCY_JOB_DATABASE_URL=
