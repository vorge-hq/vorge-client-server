# Secrets — never commit any env file (incl. variants like .env.staging,
# .env.local); .env.example is a non-secret template and is allowed.
.env
.env.*
!.env.example
node_modules/
coverage/
dist/
.DS_Store
npm-debug.log*

# Cursor IDE local files
.cursor/

# Personal notes
Notes.txt

# Local tooling — homepage spec generator + Python venv (not part of the React app)
website/

.vercel/

# Claude Code local state (commit settings.json + hooks; ignore user-local + caches)
.claude/settings.local.json
.claude/sessions/
.claude/cache/
.claude/.credentials*